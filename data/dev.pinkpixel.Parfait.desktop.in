[Desktop Entry]
Name=Parfait
Comment=Convert images between modern and traditional formats
Exec=@bindir@/parfait
Icon=dev.pinkpixel.Parfait
Terminal=false
Type=Application
Categories=Graphics;GTK;
Keywords=image;convert;webp;avif;batch;
StartupNotify=true
MimeType=image/png;image/jpeg;image/gif;image/webp;image/avif;image/bmp;image/tiff;
